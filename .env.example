# OpenAI API Key (required for GPT-4o and Whisper API fallback)
OPENAI_API_KEY=sk-your-key-here

# Optional: ATXP connection string (auto-managed by atxp)
# ATXP_CONNECTION=

# Audio device index (leave empty for default)
AUDIO_INPUT_DEVICE=

# TTS voice (Edge-TTS voice name)
TTS_VOICE=en-US-AriaNeural

# Inbound poll interval in seconds
POLL_INTERVAL=30
